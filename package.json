{
  "name": "@mustib/web-components",
  "type": "module",
  "description": "A customizable web-components library with lit",
  "private": false,
  "version": "0.0.0-alpha.9",
  "scripts": {
    "dev": "astro dev",
    "build:astro": "astro build",
    "biome": "biome check --write",
    "preview:astro": "astro preview",
    "build": "rollup -c rollup.config.js",
    "prebuild": "biome check",
    "prepublishOnly": "node -e \"throw new Error('cannot publish directly from root package use build:publish')\"",
    "build:publish": "pnpm build && cd dist && pnpm publish --access public --tag alpha",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,astro}": "biome check --write"
  },
  "dependencies": {
    "@mustib/utils": "2.11.1"
  },
  "peerDependencies": {
    "lit": "^3.3.2"
  },
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14",
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@rollup/plugin-multi-entry": "^7.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "astro": "6.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rollup": "^4.60.3",
    "rollup-plugin-dts": "^6.4.1",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1"
  }
}
