{
  "name": "@mustib/web-components",
  "type": "module",
  "description": "A customizable web-components library with lit",
  "private": false,
  "version": "0.0.0-alpha.7",
  "scripts": {
    "dev": "astro dev",
    "build:astro": "astro build",
    "biome": "biome check --write",
    "preview:astro": "astro preview",
    "build": "rollup -c rollup.config.js",
    "prebuild": "biome check",
    "prepublishOnly": "node -e \"throw new Error('cannot publish directly from root package use build:publish')\"",
    "build:publish": "pnpm build && cd dist && pnpm publish --access public --tag alpha",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,astro}": "biome check --write"
  },
  "dependencies": {
    "@mustib/utils": "2.9.0"
  },
  "peerDependencies": {
    "lit": "^3.3.1"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@rollup/plugin-multi-entry": "^7.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.9.2",
    "astro": "^5.12.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.8.1"
  }
}
