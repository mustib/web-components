  mu-sortable-item {
    @apply flex gap-1 bg-indigo-950 p-2.5 rounded-lg items-center;
  }
</style>

<Layout>
  <mu-sortable class="grid gap-2.5 w-fit">
    <mu-sortable-item name="1">
      <mu-sortable-trigger></mu-sortable-trigger>
      <span>Item 1</span>
