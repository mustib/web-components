    <mu-sortable-item name="2">
      <mu-sortable-trigger></mu-sortable-trigger>
      <span>Item 2</span>
    </mu-sortable-item>
    <mu-sortable-item name="3">
      <mu-sortable-trigger></mu-sortable-trigger>
      <span>Item 3</span>
    </mu-sortable-item>
    <mu-sortable-item name="4">
      <mu-sortable-trigger></mu-sortable-trigger>
      <span>Item 4</span>
    </mu-sortable-item>
    <mu-sortable-item name="5">
      <mu-sortable-trigger></mu-sortable-trigger>
